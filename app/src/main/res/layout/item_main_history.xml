<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="6dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cvItemHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="4dp"
        android:elevation="3dp"
        android:backgroundTint="@color/cvItemHistory"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/llItemHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/llItemHistory"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imCategory"
                android:layout_width="44dp"
                android:layout_height="44dp"
                tools:src="@drawable/icon_expense_basket" />

            <LinearLayout
                android:id="@+id/llTitleCategory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/tvNote"
                    style="@style/tvNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Магнит" />

                <TextView
                    android:id="@+id/tvCategory"
                    style="@style/tvCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Супермаркет" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAmount"
                style="@style/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="textEnd"
                tools:text="-150.00 ₽" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>