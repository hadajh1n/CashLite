<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fragAll">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitleReport"
            style="@style/tvTitleReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/tvTitleReport"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvTitleReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/cvTitleReport"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvSavingsTitle"
                    style="@style/tvSavingsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tvSavingsTitle" />

                <TextView
                    android:id="@+id/tvSavingsValue"
                    style="@style/tvSavingsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="45%"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/viewReport"
                    android:layout_marginVertical="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTitleReportIncome"
                            style="@style/tvTitleReportIncomeExpense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tvTitleReportIncome" />

                        <TextView
                            android:id="@+id/tvReportIncome"
                            style="@style/tvReportIncomeExpense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="50 000 ₽"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTitleReportExpense"
                            style="@style/tvTitleReportIncomeExpense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tvTitleReportExpense" />

                        <TextView
                            android:id="@+id/tvReportExpense"
                            style="@style/tvReportIncomeExpense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="25 000 ₽"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvTitleActivityReport"
            style="@style/tvTitleActivityReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="@string/tvTitleActivityReport"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvActivityReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/cvActivityReport"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvCountValue"
                    style="@style/tvActivityReport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Количество операций: 42"/>

                <TextView
                    android:id="@+id/tvAvgValue"
                    style="@style/tvActivityReport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Средний чек: 1 200 ₽"/>

                <TextView
                    android:id="@+id/tvMaxValue"
                    style="@style/tvActivityReport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Самый крупный расход: Супермаркеты"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvTitleTopReport"
            style="@style/tvTitleTopReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="@string/tvTitleTopReport"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvTopReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/cvTopReport"
            app:cardCornerRadius="16dp">

            <TextView
                android:id="@+id/tvTopCategoriesReport"
                style="@style/tvTopCategoriesReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:padding="16dp"
                tools:text="1. Продукты — 12 000 ₽\n2. Рестораны — 5 000 ₽\n3. Транспорт — 2 000 ₽"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>